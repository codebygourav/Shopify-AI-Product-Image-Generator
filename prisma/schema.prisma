// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum ImageVisibility {
  PUBLIC
  PRIVATE
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model Shop {
  id        String   @id @default(cuid())
  shop     String   @unique
  name      String?
  settings  String     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers   CustomerAccount[]
  generations AiImageGeneration[]
  usageLogs   OpenAiUsageLog[]
  credits     CreditLedger[]
}

model CustomerAccount {
  id                String   @id @default(cuid())
  shopId            String
  shopifyCustomerId String?
  email             String?
  displayName       String?
  passwordHash      String?
  isApproved        Boolean  @default(true)
  generationLimit   Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shop        Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  generations AiImageGeneration[]
  likes       ImageLike[]
  comments    ImageComment[]
  reviews     ImageReview[]
  credits     CreditLedger[]

  @@unique([shopId, shopifyCustomerId])
  @@index([shopId, email])
}

model AiImageGeneration {
  id                  String             @id @default(cuid())
  shopId              String
  customerId          String?
  productId           String?
  productHandle       String?
  variantId           String?
  variantTitle        String?
  selectedForCart     Boolean            @default(false)
  prompt              String             @db.Text
  imageUrl            String?            @db.Text
  shopifyMediaId      String?
  status              GenerationStatus   @default(PENDING)
  visibility          ImageVisibility    @default(PRIVATE)
  moderationStatus    ModerationStatus   @default(PENDING)
  moderationReason    String?            @db.Text
  watermarkText       String             @default("Generated by AI")
  openAiRequestId     String?
  errorMessage        String?            @db.Text
  metadata            String             @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer CustomerAccount? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  likes    ImageLike[]
  comments ImageComment[]
  reviews  ImageReview[]

  @@index([shopId, productId])
  @@index([shopId, visibility, moderationStatus])
  @@index([customerId, createdAt])
}

model ImageLike {
  id           String   @id @default(cuid())
  generationId String
  customerId   String
  createdAt    DateTime @default(now())

  generation AiImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  customer   CustomerAccount   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([generationId, customerId])
}

model ImageComment {
  id           String   @id @default(cuid())
  generationId String
  customerId   String?
  body         String
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  generation AiImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  customer   CustomerAccount?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model ImageReview {
  id           String   @id @default(cuid())
  generationId String
  customerId   String?
  rating       Int
  body         String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  generation AiImageGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  customer   CustomerAccount?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model CreditLedger {
  id          String   @id @default(cuid())
  shopId      String
  customerId  String?
  plan        SubscriptionPlan @default(FREE)
  delta       Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer CustomerAccount? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([shopId, customerId])
}

model OpenAiUsageLog {
  id             String   @id @default(cuid())
  shopId         String
  generationId   String?
  model          String
  promptTokens   Int?
  imageCount     Int      @default(1)
  requestId      String?
  status         String
  errorMessage   String?
  createdAt      DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}
