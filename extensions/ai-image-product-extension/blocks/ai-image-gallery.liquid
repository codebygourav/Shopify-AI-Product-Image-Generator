{{ 'ai-image-manager.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ai-image-manager.js' | asset_url }}" defer></script>

<section
  class="aim-community"
  data-ai-gallery
  data-api-base="{{ block.settings.api_base_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-configurator-url="{{ block.settings.configurator_url }}"
  data-product-id="{% if product %}{% if product.admin_graphql_api_id %}{{ product.admin_graphql_api_id }}{% else %}gid://shopify/Product/{{ product.id }}{% endif %}{% endif %}"
>
  <div class="aim-section-head">
    <div>
      <p class="aim-eyebrow">{{ block.settings.eyebrow }}</p>
      <h2 class="aim-heading">{{ block.settings.heading }}</h2>
    </div>
  </div>
  <div class="aim-gallery-grid" data-ai-gallery-grid></div>
</section>

{% schema %}
{
  "name": "AI community gallery",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Community gallery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Artwork generated by customers"
    },
    {
      "type": "url",
      "id": "api_base_url",
      "label": "App API base URL",
      "info": "Use your app URL during development, or your Shopify app proxy URL in production."
    },
    {
      "type": "url",
      "id": "configurator_url",
      "label": "AI configurator page URL",
      "info": "Used when a customer regenerates from a community image."
    }
  ]
}
{% endschema %}
