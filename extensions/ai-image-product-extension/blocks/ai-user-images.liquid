{{ 'ai-image-manager.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ai-image-manager.js' | asset_url }}" defer></script>

<section
  class="aim-community"
  data-ai-user-images
  data-api-base="{{ block.settings.api_base_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{% if product %}{% if product.admin_graphql_api_id %}{{ product.admin_graphql_api_id }}{% else %}gid://shopify/Product/{{ product.id }}{% endif %}{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
>
  {% if customer %}
    <div class="aim-section-head">
      <div>
        <p class="aim-eyebrow">{{ block.settings.eyebrow }}</p>
        <h2 class="aim-heading">{{ block.settings.heading }}</h2>
      </div>
    </div>
    <div class="aim-gallery-grid" data-ai-user-images-grid></div>
  {% else %}
    <div class="aim-section-head">
      <div>
        <p class="aim-eyebrow">{{ block.settings.eyebrow }}</p>
        <h2 class="aim-heading">{{ block.settings.heading }}</h2>
        <p class="aim-copy">{{ block.settings.login_message }}</p>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "AI profile images",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Your creations"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your generated images"
    },
    {
      "type": "textarea",
      "id": "login_message",
      "label": "Login message",
      "default": "Log in to view the images you created with AI."
    },
    {
      "type": "url",
      "id": "api_base_url",
      "label": "App API base URL"
    }
  ]
}
{% endschema %}
