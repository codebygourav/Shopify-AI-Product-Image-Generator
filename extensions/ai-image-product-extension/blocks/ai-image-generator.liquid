{{ 'ai-image-manager.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ai-image-manager.js' | asset_url }}" defer></script>

{% assign ai_source_product = product %}
{% if block.settings.source_product != blank %}
  {% assign ai_source_product = block.settings.source_product %}
{% endif %}


<div
  class="aim-product-studio"
  data-ai-image-generator
  data-ai-show-recent-images="{{ block.settings.show_recent_images }}"
  data-api-base="{{ block.settings.api_base_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-checkout-variant-id="{{ block.settings.checkout_variant_id }}"
  data-product-id="{% if ai_source_product and ai_source_product.admin_graphql_api_id %}{{ ai_source_product.admin_graphql_api_id }}{% elsif ai_source_product %}gid://shopify/Product/{{ ai_source_product.id }}{% endif %}"
  data-product-handle="{% if ai_source_product %}{{ ai_source_product.handle }}{% endif %}"
  data-product-title="{% if ai_source_product %}{{ ai_source_product.title | escape }}{% else %}{{ block.settings.heading | escape }}{% endif %}"
  data-product-image="{% if ai_source_product and ai_source_product.featured_image %}{{ ai_source_product.featured_image | image_url: width: 900 }}{% endif %}"
  data-money-format="{{ shop.money_format | escape }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
  data-preview-label="{{ block.settings.preview_label | escape }}"
  data-free-generation-limit="3"
>
  <div class="aim-studio-topbar">
    <div class="aim-studio-topbar__main">
      <div>
        <h2 class="aim-studio-title">Create Your Own Artwork</h2>
        <p class="aim-studio-description">{{ block.settings.description }}</p>
      </div>
    </div>
    <div class="aim-studio-usage">
      <span data-ai-usage-label aria-live="polite">0 / 3 free generations used</span>
      {% if block.settings.upgrade_url != blank %}
        <a class="aim-button aim-button--upgrade" href="{{ block.settings.upgrade_url }}" data-ai-upgrade>
          {{ block.settings.upgrade_label }}
        </a>
      {% else %}
        <button class="aim-button aim-button--upgrade" type="button" data-ai-upgrade>
          {{ block.settings.upgrade_label }}
        </button>
      {% endif %}
    </div>
  </div>

  <div class="aim-mobile-tabs" aria-label="Generator steps">
    <button class="aim-mobile-tab aim-mobile-tab--create" type="button" data-ai-mobile-tab="create">Create</button>
    <button class="aim-mobile-tab aim-mobile-tab--preview" type="button" data-ai-mobile-tab="preview">Preview</button>
  </div>

  <!-- Left Sidebar Panels -->
  <div class="aim-product-studio__panel">

    <!-- Step 1: Prompt Setup Form -->
    <div class="aim-prompt-content">
      <!-- Prompt textarea field -->
      <label class="aim-field">
        <span class="aim-setup-label">Describe your vision</span>
        <textarea
          class="aim-textarea"
          rows="4"
          maxlength="1000"
          data-ai-prompt
          placeholder="{{ block.settings.placeholder }}"
        ></textarea>
        <span class="aim-prompt-count" data-ai-prompt-count>0 / 1000</span>
      </label>

      <!-- Prompt templates / inspirations -->
      <div class="aim-prompt-tools" data-ai-prompt-tools></div>

      <!-- Orientation field -->
      <div class="aim-setup-field">
        <span class="aim-setup-label">Image orientation</span>
        <div class="aim-orientation-options">
          <button type="button" class="aim-orientation-btn is-active" data-ai-orientation-select="landscape">
            <svg class="aim-orientation-svg landscape" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"></rect></svg>
            Landscape
          </button>
          <button type="button" class="aim-orientation-btn" data-ai-orientation-select="portrait">
            <svg class="aim-orientation-svg portrait" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"></rect></svg>
            Portrait
          </button>
          <button type="button" class="aim-orientation-btn" data-ai-orientation-select="square">
            <svg class="aim-orientation-svg square" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"></rect></svg>
            Square
          </button>
        </div>
      </div>

      <!-- Effect / Style field -->
      <div class="aim-setup-field">
        <span class="aim-setup-label">Effects</span>
        <label class="aim-effect-select-field">
          <span aria-hidden="true">✦</span>
          <select data-ai-effect-select>
            <option value="none">None</option>
            <option value="abstract">Abstract</option>
            <option value="minimalist">Minimalist</option>
            <option value="retro">Retro</option>
            <option value="nature">Nature</option>
            <option value="oil-painting">Oil Painting</option>
          </select>
        </label>
      </div>

      <label class="aim-checkbox" hidden>
        <input type="checkbox" data-ai-public>
        Add approved image to community gallery
      </label>

      <div class="aim-actions">
        <button class="aim-button aim-button--outline" type="button" data-ai-edit-back hidden>
          Back to preview
        </button>
        <button class="aim-button aim-button--primary" type="button" data-ai-generate>
          {{ block.settings.button_label }}
        </button>
      </div>

      <p class="aim-generation-note">
        {% if customer %}
          Your account is connected. Generate and save artwork to your collection.
        {% else %}
          Sign up required after 3 images.
        {% endif %}
      </p>

      <p class="aim-status" data-ai-status></p>
    </div>

    <!-- Step 2: Generated Image Preview Controls -->
    <div class="aim-preview-controls-container" data-ai-preview-controls-container hidden>
      <div class="aim-prompt-panel-head">
        <p>Custom art studio</p>
        <h2>Your Generated Artwork</h2>
        <span>Select an option to refine your prompt, start over, or finalize your choices.</span>
      </div>

      <div class="aim-preview-actions-vertical">
        <button class="aim-button aim-button--primary" type="button" data-ai-preview-finalise>
          Save
        </button>
        <div class="aim-preview-row">
          <button class="aim-button aim-button--outline" type="button" data-ai-preview-edit-toggle>
            Edit Prompt
          </button>
          <button class="aim-button aim-button--outline" type="button" data-ai-preview-regenerate>
            Start Over
          </button>
        </div>
      </div>

      <div class="aim-edit-prompt-box" data-ai-edit-prompt-box hidden>
        <label class="aim-field">
          <span>Edit Prompt</span>
          <textarea class="aim-textarea" rows="3" data-ai-tweak-prompt></textarea>
        </label>
        <button class="aim-button aim-button--primary" type="button" data-ai-tweak-generate>
          Regenerate
        </button>
      </div>
    </div>

    <!-- Step 3: Customizer (Size > Frame > Color > Checkout) -->
    <div class="aim-editor-controls-container" data-ai-editor-controls-container hidden>
      <div class="aim-prompt-panel-head">
        <p>Custom art studio</p>
        <h2>Configure Product</h2>
        <span>Set size, canvas framing, and options before checking out.</span>
      </div>

      <div class="aim-editor-fields">
        <!-- 1. Select Size -->
        <div class="aim-editor-field-group">
          <h4 class="aim-section-subtitle">1. Select Size</h4>
          <div class="aim-size-controls" data-ai-size-placeholder></div>
        </div>

        <!-- 2. Choose Frame -->
        <div class="aim-editor-field-group">
          <h4 class="aim-section-subtitle">2. Choose Frame</h4>
          <label class="aim-select-field">
            <span>Frame Preset</span>
            <select data-ai-frame-type-select>
              <option value="canvas">Stretched Canvas</option>
              <option value="floating">Floating Frame</option>
            </select>
          </label>
        </div>

        <!-- 3. Frame Color -->
        <div class="aim-editor-field-group" data-ai-frame-color-group hidden>
          <h4 class="aim-section-subtitle">3. Choose Frame Color</h4>
          <label class="aim-select-field">
            <span>Frame Color</span>
            <select data-ai-frame-color-select>
              <option value="black">Matte Black</option>
              <option value="walnut">Walnut</option>
              <option value="oak">Natural Oak</option>
            </select>
          </label>
        </div>
      </div>

      <div class="aim-editor-actions-sticky">
        <button class="aim-button aim-button--outline" type="button" data-ai-editor-back>Back</button>
        <button class="aim-button aim-button--filled" type="button" data-ai-checkout-button>
          Add to Cart
        </button>
      </div>
    </div>
  </div>

  <!-- Right Area: Preview area -->
  <div class="aim-product-studio__media">
    <div class="aim-generator-empty-panel" data-ai-empty-panel>
      <div class="aim-product-studio__empty aim-product-studio__empty--studio">
        <div class="aim-empty-art" aria-hidden="true">
          <div class="aim-empty-art__plant"></div>
          <div class="aim-empty-art__easel">
            <div class="aim-empty-art__canvas">
              <span></span>
            </div>
          </div>
          <div class="aim-empty-art__tools"></div>
        </div>
        <strong>Your creativity starts here</strong>
        <p>{{ block.settings.description }}</p>
      </div>
    </div>

    <div class="aim-product-studio__preview-container" data-ai-preview-container hidden>
      <div class="aim-product-studio__preview" data-ai-preview>
        <div class="aim-product-studio__empty">
          <span>Your creativity starts here</span>
        </div>
      </div>
    </div>
  </div>

  <div class="aim-studio-auth-strip">
    <div class="aim-studio-auth-strip__copy">
      <strong>Sign up required after 3 images</strong>
      <p>
        {% if customer %}
          You can keep generating, save favorites, and continue refining your artwork.
        {% else %}
          Create an account to unlock more generations and save your favorite artwork.
        {% endif %}
      </p>
    </div>
    {% if customer %}
      <a class="aim-button aim-button--auth" href="{{ routes.account_url }}">View account</a>
    {% else %}
      <a class="aim-button aim-button--auth" href="{{ routes.account_login_url }}">Sign Up / Log In</a>
    {% endif %}
  </div>

<div class="aim-studio-benefits" aria-label="Artwork benefits">

  <div class="aim-studio-benefit">

    <div class="benefit-icon">
      <!-- AI Sparkles -->
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 2L13.5 8.5L20 10L13.5 11.5L12 18L10.5 11.5L4 10L10.5 8.5L12 2Z"
          stroke="currentColor" stroke-width="1.5"/>
        <path d="M19 15L19.8 18.2L23 19L19.8 19.8L19 23L18.2 19.8L15 19L18.2 18.2L19 15Z"
          stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>

    <div>
      <strong>AI-Powered Creation</strong>
      <p>Advanced AI models bring your ideas to life.</p>
    </div>

  </div>


  <div class="aim-studio-benefit">

    <div class="benefit-icon">
      <!-- Magic Wand -->
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M15 4L20 9L9 20L4 15L15 4Z"
          stroke="currentColor" stroke-width="1.5"/>
        <path d="M6 3V6M3 6H6M18 18V21M15 21H18"
          stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>

    <div>
      <strong>Unique & Personalized</strong>
      <p>Tailored artwork that matches your style.</p>
    </div>

  </div>


  <div class="aim-studio-benefit">

    <div class="benefit-icon">
      <!-- Diamond -->
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M6 3H18L22 9L12 21L2 9L6 3Z"
          stroke="currentColor" stroke-width="1.5"/>
        <path d="M2 9H22M9 3L7 9L12 21L17 9L15 3"
          stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>

    <div>
      <strong>High Quality Output</strong>
      <p>Museum-grade quality for your space.</p>
    </div>

  </div>


  <div class="aim-studio-benefit">

    <div class="benefit-icon">
      <!-- Infinity -->
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M18 8C15 8 12 16 9 16C6 16 4 14 4 12C4 10 6 8 9 8C12 8 15 16 18 16C21 16 22 14 22 12C22 10 21 8 18 8Z"
          stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>

    <div>
      <strong>Endless Possibilities</strong>
      <p>From concepts to masterpieces in seconds.</p>
    </div>

  </div>

</div>

{% if block.settings.show_community_gallery %}
  <div class="aim-community aim-generator-community" data-ai-gallery data-api-base="{{ block.settings.api_base_url }}" data-shop="{{ shop.permanent_domain }}" data-configurator-url="{{ request.path }}" data-community-url="{{ block.settings.community_url | default: '/pages/community-gallery' }}">
    <div class="aim-section-head">
      <div>
        <p class="aim-eyebrow">Creations</p>
        <h2 class="aim-heading">{{ block.settings.community_heading }}</h2>
        <p class="aim-copy">{{ block.settings.community_description }}</p>
      </div>
    </div>
    <div class="aim-gallery-grid aim-pinterest-grid aim-grid-loading" data-ai-gallery-grid>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
      <div class="aim-grid-loading__card" aria-hidden="true"></div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Orvella AI generator",
  "target": "section",
  "settings": [
    {
      "type": "product",
      "id": "source_product",
      "label": "Source product",
      "info": "Optional. Leave empty on product templates to use the current product dynamically."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AI Studio"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Generate your own image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Describe your idea and let AI create something unique."
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show top header banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner background image"
    },
    {
      "type": "color",
      "id": "banner_bg_color",
      "label": "Banner background color",
      "default": "#E3DCD6"
    },
    {
      "type": "color",
      "id": "banner_text_color",
      "label": "Banner text color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner title override",
      "info": "Leave blank to use dynamic title"
    },
    {
      "type": "text",
      "id": "banner_breadcrumbs",
      "label": "Banner breadcrumbs override",
      "info": "Leave blank to use dynamic breadcrumbs"
    },
    {
      "type": "range",
      "id": "banner_border_radius",
      "label": "Banner border radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "banner_overlay_opacity",
      "label": "Banner overlay opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "select",
      "id": "banner_width",
      "label": "Banner width",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "contained",
          "label": "Contained (with margins)"
        }
      ],
      "default": "full"
    },
    {
      "type": "text",
      "id": "preview_label",
      "label": "Empty preview label",
      "default": "Your creativity starts here"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Prompt placeholder",
      "default": "Describe the image you want to create..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Generate image"
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back link label",
      "default": "Back to AI Studio"
    },
    {
      "type": "url",
      "id": "back_url",
      "label": "Back link URL"
    },
    {
      "type": "text",
      "id": "upgrade_label",
      "label": "Upgrade button label",
      "default": "Upgrade for more"
    },
    {
      "type": "url",
      "id": "upgrade_url",
      "label": "Upgrade button URL"
    },
    {
      "type": "url",
      "id": "api_base_url",
      "label": "App API base URL"
    },
    {
      "type": "text",
      "id": "checkout_variant_id",
      "label": "Checkout variant ID override"
    },
    {
      "type": "checkbox",
      "id": "show_community_gallery",
      "label": "Show community gallery below generator",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_recent_images",
      "label": "Show customer generated images inside generator",
      "default": false
    },
    {
      "type": "url",
      "id": "community_url",
      "label": "Community gallery page URL"
    },
    {
      "type": "text",
      "id": "community_heading",
      "label": "Community heading",
      "default": "Community Inspirations"
    },
    {
      "type": "textarea",
      "id": "community_description",
      "label": "Community description",
      "default": "Explore what other users generated and choose your favorite artwork."
    }
  ]
}
{% endschema %}
