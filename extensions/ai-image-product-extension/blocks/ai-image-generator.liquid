{{ 'ai-image-manager.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ai-image-manager.js' | asset_url }}" defer></script>

<div
  class="aim-product-studio"
  data-ai-image-generator
  data-api-base="{{ block.settings.api_base_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{% if product.admin_graphql_api_id %}{{ product.admin_graphql_api_id }}{% else %}gid://shopify/Product/{{ product.id }}{% endif %}"
  data-product-handle="{{ product.handle }}"
  data-product-title="{{ product.title | escape }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
>
  <div class="aim-product-studio__media">
    <div class="aim-product-studio__preview" data-ai-preview>
      <div class="aim-product-studio__empty">
        <span>{{ block.settings.preview_label }}</span>
      </div>
    </div>
  </div>

  <div class="aim-product-studio__panel">
    <p class="aim-eyebrow">{{ block.settings.eyebrow }}</p>
    <h2 class="aim-heading">{{ block.settings.heading }}</h2>
    <p class="aim-copy">{{ block.settings.description }}</p>

    <div class="aim-variant-summary">
      <span>Selected product</span>
      <strong data-ai-variant-label>{{ product.selected_or_first_available_variant.title }}</strong>
    </div>

    <label class="aim-field">
      <span>Art direction</span>
      <textarea
        class="aim-textarea"
        rows="4"
        data-ai-prompt
        placeholder="{{ block.settings.placeholder }}"
      ></textarea>
    </label>

    <div class="aim-prompt-tools">
      <button type="button" class="aim-chip" data-ai-template="minimal gallery wall, premium print art, soft natural light">
        Minimal wall art
      </button>
      <button type="button" class="aim-chip" data-ai-template="bold abstract print, textured brushwork, curated interior styling">
        Abstract print
      </button>
      <button type="button" class="aim-chip" data-ai-template="calm spiritual artwork, refined color palette, elegant framed print">
        Spiritual art
      </button>
    </div>

    <label class="aim-checkbox">
      <input type="checkbox" data-ai-public>
      Add approved image to community gallery
    </label>

    <div class="aim-actions">
      <button class="aim-button aim-button--primary" type="button" data-ai-generate>
        {{ block.settings.button_label }}
      </button>
      <button class="aim-button" type="button" data-ai-select hidden>
        Use this image for checkout
      </button>
    </div>

    <p class="aim-status" data-ai-status></p>
  </div>
</div>

{% schema %}
{
  "name": "AI product image studio",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Custom AI artwork"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create your print before checkout"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Choose your product variant, describe the artwork, generate a preview, then attach the selected image to your cart item."
    },
    {
      "type": "text",
      "id": "preview_label",
      "label": "Empty preview label",
      "default": "Your generated image will appear here"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Prompt placeholder",
      "default": "Example: warm abstract botanical artwork for a walnut frame"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Generate image"
    },
    {
      "type": "url",
      "id": "api_base_url",
      "label": "App API base URL",
      "info": "Use your app URL during development, or your Shopify app proxy URL in production."
    }
  ]
}
{% endschema %}
