{{ 'ai-image-manager.css' | asset_url | stylesheet_tag }}

{% assign has_ai_images = false %}
{% for item in cart.items %}
  {% if item.properties['_AI Image URL'] != blank %}
    {% assign has_ai_images = true %}
  {% endif %}
{% endfor %}

{% if has_ai_images %}
  <section class="aim-cart-preview">
    <h2 class="aim-heading">{{ block.settings.heading }}</h2>
    <p class="aim-copy">{{ block.settings.description }}</p>
    <div class="aim-cart-preview__grid">
      {% for item in cart.items %}
        {% assign ai_image = item.properties['_AI Image URL'] %}
        {% if ai_image != blank %}
          <article class="aim-cart-preview__item">
            <img
              src="{{ ai_image }}"
              alt="Generated image for {{ item.product.title | escape }}"
              width="140"
              height="140"
              loading="lazy"
            >
            <div>
              <h3>{{ item.product.title }}</h3>
              {% if item.properties['_AI Product Variant'] != blank %}
                <p>{{ item.properties['_AI Product Variant'] }}</p>
              {% endif %}
              {% if item.properties['_AI Custom Options'] != blank %}
                <p>{{ item.properties['_AI Custom Options'] }}</p>
              {% elsif item.properties['AI Options'] != blank %}
                <p>{{ item.properties['AI Options'] }}</p>
              {% endif %}
              {% if item.properties['AI Prompt'] != blank %}
                <p><strong>Prompt:</strong> {{ item.properties['AI Prompt'] }}</p>
              {% elsif item.properties['_AI Prompt'] != blank %}
                <p><strong>Prompt:</strong> {{ item.properties['_AI Prompt'] }}</p>
              {% endif %}
              <small>Generated image selected for checkout</small>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "AI cart image preview",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Generated image preview"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Review your generated artwork before checkout."
    }
  ]
}
{% endschema %}
